{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Dressca": "Information"
    }
  },
  "WebServerOptions": {
    "AllowedOrigins": [
      "https://[本番環境のフロントエンド配布サーバーのドメイン]"
    ],
    "CookieSettings": [
      {
        "CookieName": "Dressca-Bid",
        "ExpiredDays": 7,
        "Domain": "[本番環境のフロントエンド配布サーバーのドメイン]",
        "Path": "/api"
      }
    ]
  },
  "AllowedHosts": "*"
}
